{
  "name": "stream-deck-hammerspoon",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": "24.18.0"
  },
  "workspaces": [
    "plugin"
  ],
  "scripts": {
    "build": "bun run --cwd plugin build",
    "watch": "bun run --cwd plugin watch",
    "check": "bun run --cwd plugin check && bun run lua:check",
    "test": "bun run --cwd plugin test",
    "lint": "bunx --no-install eslint .",
    "format": "bunx --no-install prettier --write .",
    "lua:check": "mise exec -- lua -e \"assert(loadfile('hammerspoon/streamdeck/init.lua'))\"",
    "validate": "bun run build && bunx --no-install streamdeck validate plugin/com.brettinternet.hammerspoon.sdPlugin",
    "pack": "bun run build && bunx --no-install streamdeck pack plugin/com.brettinternet.hammerspoon.sdPlugin"
  },
  "devDependencies": {
    "@elgato/cli": "1.7.4",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0"
  }
}
