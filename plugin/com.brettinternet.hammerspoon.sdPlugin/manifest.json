{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "Actions": [
    {
      "Name": "Hammerspoon Button",
      "Tooltip": "Run a Hammerspoon action",
      "Controllers": [
        "Keypad",
        "Encoder"
      ],
      "DisableAutomaticStates": true,
      "Encoder": {
        "layout": "$A1",
        "TriggerDescription": {
          "Push": "Run Hammerspoon action",
          "Rotate": "Adjust Hammerspoon action",
          "Touch": "Tap Hammerspoon action"
        }
      },
      "Icon": "imgs/action",
      "PropertyInspectorPath": "ui/property-inspector.html",
      "States": [
        {
          "FontSize": 12,
          "Image": "imgs/button",
          "Name": "Button",
          "ShowTitle": true,
          "Title": "Button",
          "TitleAlignment": "middle"
        }
      ],
      "UUID": "com.brettinternet.hammerspoon.button"
    },
    {
      "Name": "Hammerspoon Toggle",
      "Tooltip": "Toggle a Hammerspoon action",
      "Controllers": [
        "Keypad",
        "Encoder"
      ],
      "DisableAutomaticStates": true,
      "Encoder": {
        "layout": "$A1",
        "TriggerDescription": {
          "Push": "Run Hammerspoon action",
          "Rotate": "Adjust Hammerspoon action",
          "Touch": "Tap Hammerspoon action"
        }
      },
      "Icon": "imgs/action",
      "PropertyInspectorPath": "ui/property-inspector.html",
      "States": [
        {
          "FontSize": 12,
          "Image": "imgs/toggle-off",
          "Name": "Inactive",
          "ShowTitle": true,
          "Title": "Off",
          "TitleAlignment": "middle"
        },
        {
          "FontSize": 12,
          "Image": "imgs/toggle-on",
          "Name": "Active",
          "ShowTitle": true,
          "Title": "On",
          "TitleAlignment": "middle"
        }
      ],
      "UUID": "com.brettinternet.hammerspoon.action"
    },
    {
      "Name": "Hammerspoon Multi-State",
      "Tooltip": "Run a Hammerspoon action with four presentation states",
      "Controllers": [
        "Keypad"
      ],
      "DisableAutomaticStates": true,
      "Icon": "imgs/action",
      "PropertyInspectorPath": "ui/property-inspector.html",
      "States": [
        {
          "FontSize": 12,
          "Image": "imgs/multistate-0",
          "Name": "State 0",
          "ShowTitle": true,
          "Title": "State 0",
          "TitleAlignment": "middle"
        },
        {
          "FontSize": 12,
          "Image": "imgs/multistate-1",
          "Name": "State 1",
          "ShowTitle": true,
          "Title": "State 1",
          "TitleAlignment": "middle"
        },
        {
          "FontSize": 12,
          "Image": "imgs/multistate-2",
          "Name": "State 2",
          "ShowTitle": true,
          "Title": "State 2",
          "TitleAlignment": "middle"
        },
        {
          "FontSize": 12,
          "Image": "imgs/multistate-3",
          "Name": "State 3",
          "ShowTitle": true,
          "Title": "State 3",
          "TitleAlignment": "middle"
        }
      ],
      "UUID": "com.brettinternet.hammerspoon.multistate"
    }
  ],
  "Author": "Brett",
  "Category": "Hammerspoon",
  "CategoryIcon": "imgs/category",
  "CodePath": "bin/plugin.js",
  "Description": "Control Hammerspoon actions from Stream Deck.",
  "Icon": "imgs/plugin",
  "Name": "Hammerspoon",
  "Nodejs": {
    "Debug": "enabled",
    "Version": "24"
  },
  "OS": [
    {
      "MinimumVersion": "13",
      "Platform": "mac"
    }
  ],
  "SDKVersion": 2,
  "Software": {
    "MinimumVersion": "7.1"
  },
  "UUID": "com.brettinternet.hammerspoon",
  "Version": "0.4.0.0"
}