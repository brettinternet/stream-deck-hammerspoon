{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "Actions": [
    {
      "Name": "Hammerspoon Action",
      "Controllers": [
        "Keypad",
        "Encoder"
      ],
      "DisableAutomaticStates": true,
      "Encoder": {
        "layout": "$A1",
        "TriggerDescription": {
          "Push": "Run Hammerspoon action",
          "Rotate": "Adjust Hammerspoon action",
          "Touch": "Tap Hammerspoon action"
        }
      },
      "Icon": "imgs/action",
      "PropertyInspectorPath": "ui/property-inspector.html",
      "States": [
        {
          "FontSize": 14,
          "Image": "imgs/key",
          "Name": "Inactive",
          "ShowTitle": true,
          "Title": "Hammerspoon Action",
          "TitleAlignment": "middle"
        },
        {
          "FontSize": 14,
          "Image": "imgs/key",
          "Name": "Active",
          "ShowTitle": true,
          "Title": "Hammerspoon Action",
          "TitleAlignment": "middle"
        }
      ],
      "UUID": "com.brettinternet.hammerspoon.action"
    }
  ],
  "Author": "Brett",
  "Category": "Hammerspoon",
  "CodePath": "bin/plugin.js",
  "Description": "Control Hammerspoon actions from Stream Deck.",
  "Icon": "imgs/plugin",
  "Name": "Hammerspoon",
  "Nodejs": {
    "Debug": "enabled",
    "Version": "24"
  },
  "OS": [
    {
      "MinimumVersion": "13",
      "Platform": "mac"
    }
  ],
  "SDKVersion": 2,
  "Software": {
    "MinimumVersion": "7.1"
  },
  "UUID": "com.brettinternet.hammerspoon",
  "Version": "1.2.3.4"
}